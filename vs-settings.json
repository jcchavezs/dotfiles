{
    "workbench.startupEditor": "newUntitledFile",
    "editor.fontSize": 15,
    "files.exclude": {
        "**/.idea": true,
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true,
        "**/*.pyc": {
            "when": "$(basename).py"
        },
        "**/__pycache__": true
    },
    "terminal.integrated.fontSize": 15,
    "php.validate.executablePath": "php",
    "go.formatTool": "goimports",
    "editor.suggestSelection": "first",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.explorerKind": "external",
    "terminal.integrated.shell.osx": "/bin/zsh",
    "[go]": {
        "editor.formatOnSave": true
    },
    "latex-workshop.view.pdf.viewer": "tab",
    "go.useLanguageServer": true,
    "C_Cpp.updateChannel": "Insiders",
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "javascript.format.enable": false,
    "php-cs-fixer.executable": "~/.composer/vendor/bin/php-cs-fixer",
    "php-cs-fixer.pathMode": "override",
    "vs-kubernetes": {
        "vs-kubernetes.minikube-path": "/Users/joschavez/.vs-kubernetes/tools/minikube/darwin-amd64/minikube"
    },
    "xml.format.splitAttributes": true,
    "namespaceResolver.sortOnSave": true,
    "namespaceResolver.sortNatural": true,
    "namespaceResolver.showMessageOnStatusBar": true,
    "symfony-vscode.enableFileWatching": false,
    "[java]": {
        "editor.defaultFormatter": "mngrm3a.vscode-google-java-formatter"
    },
    "editor.minimap.enabled": false,
    "editor.accessibilitySupport": "off",
    "go.toolsManagement.autoUpdate": true,
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter.notebook.ipynb"
    },
    "redhat.telemetry.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "yaml.schemas": {
        "https://github.com/jcchavezs/envoy-config-schema/releases/download/v1.21.0/v3_Bootstrap.json": "envoy-config.yaml",
        "file:///Users/josecarlos.chavez/Workspace/source/github.com/atko-cic/pipeline-cli/schemas/ProjectManifest.json": "project.yaml"
    },
    "[python]": {
        "editor.formatOnType": true
    },
    "launch": {
        "configurations": [],
        "compounds": []
    },
    "go.testTimeout": "300s",
    "window.commandCenter": false,
    "window.zoomLevel": 2,
    "security.workspace.trust.untrustedFiles": "open",
    "githubPullRequests.pullBranch": "never",
    "githubPullRequests.pushBranch": "always",
    "github.copilot.editor.enableAutoCompletions": true,
    "go.alternateTools": {},
    "go.toolsManagement.go": "/opt/homebrew/bin/go",
    "go.gopath": "",
    "update.showReleaseNotes": false,
    "git.openRepositoryInParentFolders": "never",
    "docker.extension.enableComposeLanguageServer": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "atlascode.bitbucket.enabled": false,
    "atlascode.jira.todoIssues.enabled": false,
    "claudeCode.environmentVariables": [
        {
            "name": "CLAUDE_CODE_USE_BEDROCK",
            "value": "1"
        }
    ],
    "claudeCode.preferredLocation": "panel",
    "chat.tools.terminal.autoApprove": {
        "go": true
    }
}